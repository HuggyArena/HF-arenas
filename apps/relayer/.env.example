NODE_ENV=production
PORT=3001

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/arena

# Chain
CHAIN_ID=137
RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Contracts
USDC_ADDRESS=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
ADMIN_ADDRESS=0x0000000000000000000000000000000000000001

# Signing / oracle
ORACLE_PRIVATE_KEY=REPLACE_WITH_ORACLE_PRIVATE_KEY

# Gelato gasless relay
GELATO_API_KEY=REPLACE_WITH_GELATO_API_KEY

# Compliance — set SANCTIONS_PROVIDER to TRM or CHAINALYSIS
SANCTIONS_PROVIDER=TRM
TRM_API_KEY=REPLACE_WITH_TRM_API_KEY
CHAINALYSIS_API_KEY=REPLACE_WITH_CHAINALYSIS_API_KEY

# Sumsub KYC
SUMSUB_APP_TOKEN=REPLACE_WITH_SUMSUB_APP_TOKEN
SUMSUB_SECRET_KEY=REPLACE_WITH_SUMSUB_SECRET_KEY
